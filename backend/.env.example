# ─── Base de datos PostgreSQL ─────────────────────────────────────────────────
# Dev (docker-compose): postgresql://neurax:neurax_dev_pass@localhost:5434/neurax_dev
# Prod (Supabase self-hosted): postgresql://user:pass@supabase-host/neurax_prod?sslmode=require
DATABASE_URL=postgresql://neurax:neurax_dev_pass@localhost:5434/neurax_dev

# ─── Redis ────────────────────────────────────────────────────────────────────
# Dev (docker-compose): redis://localhost:6381
# Prod (Redis en Coolify): redis://redis:6379
REDIS_URL=redis://localhost:6381

# ─── JWT (mínimo 32 caracteres en producción) ─────────────────────────────────
JWT_SECRET=dev_jwt_secret_change_in_prod
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_prod

# ─── MinIO (self-hosted S3-compatible) ────────────────────────────────────────
# Dev: http://localhost:9000 (docker-compose)
# Prod: URL del contenedor MinIO en Coolify
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=neurax_minio_key
MINIO_SECRET_KEY=neurax_minio_secret
MINIO_BUCKET=neurax-media

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
