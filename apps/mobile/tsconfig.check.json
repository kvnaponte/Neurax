{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "react": ["./node_modules/react"],
      "react-native": ["./node_modules/react-native"],
      "react-native-svg": ["./node_modules/react-native-svg"],
      "react-native-reanimated": ["./node_modules/react-native-reanimated"],
      "expo-font": ["./node_modules/expo-font"],
      "expo-splash-screen": ["./node_modules/expo-splash-screen"],
      "expo-router": ["./node_modules/expo-router"],
      "expo-status-bar": ["./node_modules/expo-status-bar"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
