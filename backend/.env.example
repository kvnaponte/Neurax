# ─── Base de datos PostgreSQL ─────────────────────────────────────────────────
# Dev (docker-compose): postgresql://neurax:neurax_dev_pass@localhost:5434/neurax_dev
# Prod (Neon):          postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neurax_prod?sslmode=require
DATABASE_URL=postgresql://neurax:neurax_dev_pass@localhost:5434/neurax_dev

# ─── Redis ────────────────────────────────────────────────────────────────────
# Dev (docker-compose): redis://localhost:6381
# Prod (Upstash):       rediss://default:xxx@xxx.upstash.io:6379
REDIS_URL=redis://localhost:6381

# ─── JWT (mínimo 32 caracteres en producción) ─────────────────────────────────
JWT_SECRET=dev_jwt_secret_change_in_prod
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_prod

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Obtener en: cloudinary.com → Settings → API Keys
# Formato: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
